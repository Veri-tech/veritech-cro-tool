{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "server.js": {
      "includeFiles": "dist/**",
      "maxDuration": 55
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*\\.(js|css|ico|png|jpg|jpeg|svg|woff|woff2|ttf|map))",
      "dest": "/dist/client/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
