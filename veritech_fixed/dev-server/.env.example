# ─── Supabase (auto-populated by Lovable Cloud) ───────────────
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── App URL (no trailing slash) ──────────────────────────────
APP_URL=

# ─── Google OAuth (GA4 + Search Console) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Semrush OAuth ────────────────────────────────────────────
SEMRUSH_CLIENT_ID=
SEMRUSH_CLIENT_SECRET=

# ─── Email ────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Token encryption (AES-256-GCM) ──────────────────────────
# Generate with: openssl rand -hex 32
SUPABASE_ENCRYPTION_KEY=

# ─── DataForSEO (competitor traffic fallback) ─────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ─── Internal key alias (backwards compat) ────────────────────
# INTEGRATION_ENCRYPTION_KEY=   ← use SUPABASE_ENCRYPTION_KEY instead
