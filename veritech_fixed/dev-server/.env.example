# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Client-side Supabase (Vite needs VITE_ prefix for browser bundle) ────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── App URL (no trailing slash) ──────────────────────────────────────────────
APP_URL=https://your-app.vercel.app

# ─── Token encryption (AES-256-GCM) ──────────────────────────────────────────
# Generate: openssl rand -hex 32
SUPABASE_ENCRYPTION_KEY=your_64_char_hex_string

# ─── Google OAuth (GA4 + Search Console) ──────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Semrush OAuth ────────────────────────────────────────────────────────────
SEMRUSH_CLIENT_ID=your_semrush_client_id
SEMRUSH_CLIENT_SECRET=your_semrush_client_secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── DataForSEO (competitor traffic fallback) ─────────────────────────────────
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password
